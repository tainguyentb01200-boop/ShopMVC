@model LoginViewModel
@using ShopMVC.ViewModels
@{
    ViewData["Title"] = "Đăng nhập";
}

<style>
    /* Import Font */
    @@import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800;900&display=swap');

    /* Scoped CSS */
    .login-page-wrapper {
        font-family: 'Be Vietnam Pro', sans-serif !important;
        color: black;
        background: #f5f5f7;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
    }

    .login-page-wrapper :root {
        --primary: #0071e3;
        --bg-input: #f5f5f7;
        --radius-card: 32px;
    }

    /* LOGIN CARD */
    .login-card {
        background: #fff;
        border-radius: 20px;
        padding: 60px 50px;
        width: 100%;
        max-width: 550px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        text-align: center;
        margin: 20px;
    }

    /* HEADER */
    .login-icon {
        font-size: 4rem;
        color: #0071e3;
        margin-bottom: 20px;
        display: inline-block;
        animation: float 3s ease-in-out infinite;
    }

    .login-title {
        font-family: 'Be Vietnam Pro';
        font-size: 4rem;
        font-weight: 800;
        margin-bottom: 10px;
        color: black;
        letter-spacing: -0.02em;
    }

    .login-subtitle {
        font-size: 1.6rem;
        color: black;
        margin-bottom: 40px;
    }

    /* FORM */
    .form-group {
        margin-bottom: 10px;
        text-align: left;
    }

    .form-label {
        font-size: 1.7rem;
        font-weight: 600;
        margin-bottom: 8px;
        display: block;
        color: black;
    }

    .input-wrapper {
        position: relative;
    }

    /* removed invalid rule and ensure input text is black */
    .form-input,
    input.form-input {
        width: 100%;
        padding: 25px 30px;
        padding-left: 65px; /* Chừa chỗ cho icon */
        background: var(--bg-input);
        border: 1px solid transparent;
        border-radius: 16px;
        font-size: 1.8rem;
        color: black;
        transition: 0.3s;
        outline: none;
    }

    /* Placeholder inside .form-input explicitly black */
    .form-input::placeholder,
    input.form-input::placeholder {
        color: #000 !important;
        opacity: 1 !important;
    }

    .form-input:focus {
        background: #fff;
        border-color: #0071e3;
        box-shadow: 0 0 0 4px rgba(0, 113, 227, 0.1);
        color: black !important; /* FIX LỖI: Ép màu chữ đen khi focus */
    }

    .input-icon {
        position: absolute;
        left: 18px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.8rem;
        color: black;
    }

    /* CHECKBOX */
    .form-check {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 30px;
    }
    .form-check-input {
        width: 20px; height: 20px;
        cursor: pointer;
        transform: scale(1.2);
    }
    .form-check-label {
        font-size: 1.8rem;
        color: black;
        cursor: pointer;
        padding-top: 3px;
    }


    /* BUTTON */
    .btn-login {
        width: 100%;
        padding: 18px;
        border-radius: 99px;
        background: #0071e3;
        color: #fff;
        font-size: 2rem;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: 0.3s;
        display: flex; align-items: center; justify-content: center; gap: 10px;
    }

    .btn-login:hover {
        background: #005bb5;
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(0, 113, 227, 0.3);
    }

    /* FOOTER LINKS */
    .login-footer {
        margin-top: 30px;
        font-size: 1.8rem;
        color: black;
    }
    .login-link {
        color: #0071e3;
        font-weight: 700;
        text-decoration: none;
        transition: 0.2s;
    }
    .login-link:hover { text-decoration: underline; }

    /* ALERTS */
    .alert-custom {
        padding: 15px; border-radius: 12px;
        margin-bottom: 20px;
        font-size: 1.7rem; text-align: left;
        display: flex; align-items: center; gap: 10px;
    }
    .alert-danger { background: #ffe6e6; color: #ff3b30; border: 1px solid #ffcccc; }
    .alert-success { background: #e8fce8; color: #34c759; border: 1px solid #c3e6cb; }

    /* ANIMATION */
    @@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
    .reveal { opacity: 0; transform: translateY(30px); transition: 0.8s ease-out; }
    .reveal.active { opacity: 1; transform: translateY(0); }
    /* Khi focus thì đổi nền input autofill sang trắng cho đẹp */
    input:focus:-webkit-autofill {
        -webkit-box-shadow: 0 0 0 30px #ffffff inset !important; 
    }

</style>

<div class="login-page-wrapper">
    <div class="login-card reveal">
        <div class="login-header">
            <div class="login-icon">
                <i class="fa-solid fa-fingerprint"></i>
            </div>
            <h1 class="login-title">Chào mừng bạn trở lại</h1>
            <p class="login-subtitle">Vui lòng đăng nhập để tiếp tục trải nghiệm</p>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="alert-custom alert-danger">
                <i class="fa-solid fa-circle-exclamation"></i>
                <span>@TempData["Error"]</span>
            </div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert-custom alert-success">
                <i class="fa-solid fa-circle-check"></i>
                <span>@TempData["Success"]</span>
            </div>
        }

       <form asp-controller="Account" asp-action="Login" method="post" autocomplete="off">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 1.4rem; text-align: left;"></div>

    <div class="form-group">
        <label asp-for="Username" class="form-label">Tên đăng nhập</label>
        <div class="input-wrapper">
            <i class="fa-regular fa-user input-icon"></i>
            <input asp-for="Username" class="form-input" style="padding-left: 40px;" 
                   placeholder="Nhập username" autofocus autocomplete="off" />
        </div>
        <span asp-validation-for="Username" class="text-danger" style="font-size: 1.3rem; display: block; margin-top: 5px;"></span>
    </div>

    <div class="form-group">
        <label asp-for="Password" class="form-label">Mật khẩu</label>
        <div class="input-wrapper">
            <i class="fa-solid fa-lock input-icon"></i>
            <input asp-for="Password" type="password" style="padding-left: 40px;" class="form-input" 
                   placeholder="Nhập mật khẩu" autocomplete="new-password" />
        </div>
        <span asp-validation-for="Password" class="text-danger" style="font-size: 1.3rem; display: block; margin-top: 5px;"></span>
    </div>

    <div class="form-check">
        <input asp-for="RememberMe" class="form-check-input" type="checkbox" id="rememberCheck" />
        <label asp-for="RememberMe" class="form-check-label" for="rememberCheck">
            Ghi nhớ phiên đăng nhập
        </label>
    </div>

    <button type="submit" class="btn-login">
        Đăng nhập <i class="fa-solid fa-arrow-right"></i>
    </button>

    <div class="login-footer">
        <p>Chưa có tài khoản? <a asp-controller="Account" asp-action="Register" class="login-link">Đăng ký ngay</a></p>
    </div>
</form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Animation Reveal
        document.addEventListener('DOMContentLoaded', () => {
            setTimeout(() => {
                document.querySelector('.reveal').classList.add('active');
            }, 100);
        });
    </script>
}