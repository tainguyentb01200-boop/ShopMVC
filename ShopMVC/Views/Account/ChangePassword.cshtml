@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Import Font */
    @@import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800;900&display=swap');

    /* Scoped CSS */
    .password-wrapper {
        font-family: 'Be Vietnam Pro', sans-serif !important;
        color: #1d1d1f;
        background: #f5f5f7; /* Nền xám nhạt tổng thể */
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 20px;
        font-size: 1.6rem;
        line-height: 1.6;
    }

        .password-wrapper :root {
            --primary: #0071e3;
            --bg-input: #f5f5f7;
            --text-sub: #86868b;
            --radius-card: 24px;
        }

    /* CARD CONTAINER */
    .password-card {
        background: #fff;
        border-radius: var(--radius-card);
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        width: 100%;
        max-width: 600px;
        padding: 50px;
        text-align: center;
    }

    /* HEADER */
    .icon-lock {
        width: 80px;
        height: 80px;
        background: rgba(0, 113, 227, 0.1);
        color: #0071e3;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        margin: 0 auto 20px;
    }

    .page-title {
        font-size: 3rem;
        font-weight: 800;
        margin-bottom: 10px;
        color: #1d1d1f;
    }

    .page-desc {
        font-size: 1.6rem;
        color: #86868b;
        margin-bottom: 40px;
    }

    /* FORM ELEMENTS */
    .form-group {
        margin-bottom: 25px;
        text-align: left;
    }

    .form-label {
        font-size: 1.4rem;
        font-weight: 600;
        color: #1d1d1f;
        margin-bottom: 8px;
        display: block;
    }

    .input-group-custom {
        position: relative;
        display: flex;
        align-items: center;
    }

    .custom-input {
        width: 100%;
        padding: 16px 20px;
        padding-right: 50px;
        background: var(--bg-input);
        border: 1px solid transparent;
        border-radius: 12px;
        font-size: 1.6rem;
        color: #1d1d1f;
        transition: 0.3s;
    }

        .custom-input:focus {
            background: #fff;
            border-color: #0071e3;
            box-shadow: 0 0 0 4px rgba(0, 113, 227, 0.1);
            outline: none;
        }

    .toggle-password {
        position: absolute;
        right: 15px;
        background: none;
        border: none;
        cursor: pointer;
        color: #86868b;
        font-size: 1.6rem;
        display: flex;
        align-items: center;
    }

        .toggle-password:hover {
            color: #0071e3;
        }

    /* REQUIREMENTS BOX */
    .requirements-box {
        background: #f0f8ff;
        border: 1px solid #cce5ff;
        border-radius: 12px;
        padding: 20px;
        text-align: left;
        margin-bottom: 30px;
    }

    .req-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: #004085;
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .req-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

        .req-list li {
            font-size: 1.3rem;
            color: #004085;
            margin-bottom: 5px;
            position: relative;
            padding-left: 20px;
        }

            .req-list li::before {
                content: '•';
                position: absolute;
                left: 5px;
                color: #0071e3;
                font-weight: bold;
            }

    /* BUTTONS */
    .btn-submit {
        width: 100%;
        padding: 18px;
        border-radius: 99px;
        background: #0071e3;
        color: #fff;
        font-size: 1.6rem;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: 0.3s;
        margin-bottom: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

        .btn-submit:hover {
            background: #005bb5;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,113,227,0.3);
        }

    .btn-cancel {
        width: 100%;
        padding: 16px;
        border-radius: 99px;
        background: transparent;
        color: #86868b;
        font-size: 1.6rem;
        font-weight: 600;
        border: none;
        cursor: pointer;
        text-decoration: none;
        display: block;
    }

        .btn-cancel:hover {
            color: #1d1d1f;
            background: #f5f5f7;
        }

    /* ALERT */
    .alert-custom {
        padding: 15px;
        border-radius: 12px;
        margin-bottom: 20px;
        text-align: left;
        font-size: 1.4rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .alert-success {
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    .alert-danger {
        background: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }

    /* Animation */
    .reveal {
        opacity: 0;
        transform: translateY(20px);
        transition: 0.6s ease-out;
    }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }
</style>

<div class="password-wrapper">
    <div class="password-card reveal">
        <div class="icon-lock">
            <i class="fa-solid fa-shield-halved"></i>
        </div>
        <h1 class="page-title">Đổi mật khẩu</h1>
        <p class="page-desc">Vui lòng nhập mật khẩu hiện tại và mật khẩu mới để bảo vệ tài khoản của bạn.</p>

        @if (TempData["Success"] != null)
        {
            <div class="alert-custom alert-success">
                <i class="fa-solid fa-circle-check"></i>
                <span>@TempData["Success"]</span>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-custom alert-danger">
                <i class="fa-solid fa-circle-exclamation"></i>
                <span>@TempData["Error"]</span>
            </div>
        }

        <form asp-action="ChangePassword" method="post" id="changePassForm">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label">Mật khẩu hiện tại</label>
                <div class="input-group-custom">
                    <input type="password" name="oldPassword" id="oldPassword" class="custom-input" placeholder="Nhập mật khẩu cũ..." required>
                    <button type="button" class="toggle-password" onclick="togglePassword('oldPassword')">
                        <i class="fa-regular fa-eye" id="oldPassword-icon"></i>
                    </button>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Mật khẩu mới</label>
                <div class="input-group-custom">
                    <input type="password" name="newPassword" id="newPassword" class="custom-input" placeholder="Nhập mật khẩu mới..." required minlength="6">
                    <button type="button" class="toggle-password" onclick="togglePassword('newPassword')">
                        <i class="fa-regular fa-eye" id="newPassword-icon"></i>
                    </button>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Xác nhận mật khẩu mới</label>
                <div class="input-group-custom">
                    <input type="password" name="confirmPassword" id="confirmPassword" class="custom-input" placeholder="Nhập lại mật khẩu mới..." required minlength="6">
                    <button type="button" class="toggle-password" onclick="togglePassword('confirmPassword')">
                        <i class="fa-regular fa-eye" id="confirmPassword-icon"></i>
                    </button>
                </div>
            </div>

            <div class="requirements-box">
                <div class="req-title"><i class="fa-solid fa-circle-info"></i> Lưu ý bảo mật:</div>
                <ul class="req-list">
                    <li>Mật khẩu phải có ít nhất 6 ký tự.</li>
                    <li>Nên kết hợp chữ hoa, chữ thường và số.</li>
                    <li>Không chia sẻ mật khẩu cho người khác.</li>
                </ul>
            </div>

            <button type="submit" class="btn-submit">
                Cập nhật mật khẩu <i class="fa-solid fa-arrow-right"></i>
            </button>
            <a asp-action="Profile" class="btn-cancel">Hủy bỏ, quay lại</a>
        </form>
    </div>
</div>

<script>
    // Reveal Animation
    document.addEventListener('DOMContentLoaded', () => {
        setTimeout(() => document.querySelector('.reveal').classList.add('active'), 100);
    });

    // Toggle Password Visibility
    function togglePassword(fieldId) {
        const field = document.getElementById(fieldId);
        const icon = document.getElementById(fieldId + '-icon');

        if (field.type === 'password') {
            field.type = 'text';
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
        } else {
            field.type = 'password';
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
        }
    }

    // Validate Match
    document.getElementById('changePassForm').addEventListener('submit', function(e) {
        const newPass = document.getElementById('newPassword').value;
        const confirmPass = document.getElementById('confirmPassword').value;

        if (newPass !== confirmPass) {
            e.preventDefault();
            // Có thể dùng Toast thay vì alert nếu muốn đẹp hơn
            alert('Mật khẩu xác nhận không khớp! Vui lòng kiểm tra lại.');
        }
    });
</script>