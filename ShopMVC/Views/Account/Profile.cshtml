@model ShopMVC.Models.User
@{
    ViewData["Title"] = "Thông tin cá nhân";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Import Font */
    @@import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800;900&display=swap');

    /* Scoped CSS */
    .profile-wrapper {
        font-family: 'Be Vietnam Pro', sans-serif !important;
        color: #1d1d1f;
        background: #f5f5f7;
        min-height: 100vh;
        padding: 60px 0;
        font-size: 1.6rem;
        line-height: 1.6;
    }

        .profile-wrapper :root {
            --primary: #0071e3;
            --bg-card: #ffffff;
            --bg-input: #f5f5f7;
            --text-sub: #86868b;
            --radius-card: 30px;
        }

    /* 1. PROFILE HEADER CARD */
    .profile-card {
        background: #fff;
        border-radius: var(--radius-card);
        padding: 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        margin-bottom: 30px;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .avatar-box {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg, #0071e3 0%, #42a1ff 100%);
        color: #fff;
        font-size: 5rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        box-shadow: 0 10px 20px rgba(0, 113, 227, 0.3);
    }

    .user-fullname {
        font-family: Be VietNam Pro;
        font-size: 3rem;
        font-weight: 800;
        margin-bottom: 5px;
        color: #1d1d1f;
    }

    .user-username {
        font-size: 1.8rem;
        color: #86868b;
        font-weight: 500;
        margin-bottom: 20px;
    }

    .badges-container {
        display: flex;
        justify-content: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .info-pill {
        padding: 8px 20px;
        border-radius: 99px;
        background: #f5f5f7;
        color: #1d1d1f;
        font-size: 1.4rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .pill-role {
        background: #e6f2ff;
        color: #0071e3;
    }

    .pill-id {
        background: #fff0e6;
        color: #ff9500;
    }

    .pill-status {
        background: #e8fce8;
        color: #34c759;
    }

    /* 2. EDIT FORM CARD */
    .form-card {
        background: #fff;
        border-radius: var(--radius-card);
        padding: 50px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .section-title {
        font-size: 2.4rem;
        font-weight: 700;
        margin-bottom: 30px;
        padding-bottom: 15px;
        border-bottom: 1px solid #f5f5f7;
    }

    .form-group {
        margin-bottom: 25px;
    }

    .form-label {
        font-size: 1.4rem;
        font-weight: 600;
        color: #1d1d1f;
        margin-bottom: 8px;
        display: block;
    }

    .custom-input {
        width: 100%;
        padding: 16px 20px;
        background: var(--bg-input);
        border: 1px solid transparent;
        border-radius: 16px;
        font-size: 1.6rem;
        color: #1d1d1f;
        transition: 0.3s;
    }

        .custom-input:focus {
            background: #fff;
            border-color: #0071e3;
            box-shadow: 0 0 0 4px rgba(0, 113, 227, 0.1);
            outline: none;
        }

        .custom-input[readonly] {
            background: #f9f9f9;
            color: #999;
            cursor: not-allowed;
        }

    /* Buttons */
    .btn-action {
        width: 100%;
        padding: 18px;
        border-radius: 99px;
        font-size: 1.6rem;
        font-weight: 700;
        border: none;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
    }

    .btn-save {
        background: #0071e3;
        color: #fff;
    }

        .btn-save:hover {
            background: #005bb5;
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(0,113,227,0.3);
        }

    .btn-pass {
        background: #fff;
        color: #1d1d1f;
        border: 2px solid #e5e5ea;
    }

        .btn-pass:hover {
            border-color: #1d1d1f;
            background: #1d1d1f;
            color: #fff;
        }

    /* Alerts */
    .alert-custom {
        padding: 15px;
        border-radius: 16px;
        margin-bottom: 25px;
        font-size: 1.5rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .alert-success {
        background: #e8fce8;
        color: #34c759;
        border: 1px solid #c3e6cb;
    }

    .alert-danger {
        background: #ffe6e6;
        color: #ff3b30;
        border: 1px solid #ffcccc;
    }

    /* Animation */
    .reveal {
        opacity: 0;
        transform: translateY(30px);
        transition: 0.6s ease-out;
    }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }
</style>

<div class="profile-wrapper">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 mb-4 reveal">
                <div class="profile-card">
                    <div class="avatar-box">
                        @Model.Username.Substring(0, 1).ToUpper()
                    </div>
                    <h1 class="user-fullname">@Model.FullName</h1>
                    <p class="user-username">@@@Model.Username</p>

                    <div class="badges-container">
                        <div class="info-pill pill-id">
                            <i class="fa-solid fa-fingerprint"></i> ID: @Model.UserId
                        </div>
                        <div class="info-pill pill-role">
                            <i class="fa-solid fa-shield-halved"></i> @Model.Role
                        </div>
                        <div class="info-pill pill-status">
                            <i class="fa-solid fa-circle-check"></i> @(Model.IsActive ? "Hoạt động" : "Bị khóa")
                        </div>
                        <div class="info-pill">
                            <i class="fa-regular fa-calendar"></i> Tham gia: @Model.CreatedDate.ToString("dd/MM/yyyy")
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8 reveal" style="transition-delay: 0.1s">
                @if (TempData["Success"] != null)
                {
                    <div class="alert-custom alert-success">
                        <i class="fa-solid fa-check-circle"></i> @TempData["Success"]
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert-custom alert-danger">
                        <i class="fa-solid fa-circle-exclamation"></i> @TempData["Error"]
                    </div>
                }

                <div class="form-card">
                    <h3 class="section-title">Thông tin cá nhân</h3>

                    <form asp-action="UpdateProfile" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="Username" />
                        <input type="hidden" asp-for="Password" />
                        <input type="hidden" asp-for="Role" />
                        <input type="hidden" asp-for="IsActive" />
                        <input type="hidden" asp-for="CreatedDate" />

                        <div class="row">
                            <div class="col-md-6 form-group">
                                <label class="form-label">Họ và tên</label>
                                <input asp-for="FullName" class="custom-input" placeholder="Nhập họ tên..." />
                                <span asp-validation-for="FullName" class="text-danger mt-1 d-block"></span>
                            </div>
                            <div class="col-md-6 form-group">
                                <label class="form-label">Số điện thoại</label>
                                <input asp-for="Phone" class="custom-input" placeholder="09xx..." />
                                <span asp-validation-for="Phone" class="text-danger mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Email</label>
                            <input asp-for="Email" type="email" class="custom-input" placeholder="email@example.com" />
                            <span asp-validation-for="Email" class="text-danger mt-1 d-block"></span>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Tên đăng nhập (Không thể đổi)</label>
                            <input type="text" class="custom-input" value="@Model.Username" readonly />
                        </div>

                        <div class="row mt-5">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <button type="submit" class="btn-action btn-save">
                                    <i class="fa-solid fa-floppy-disk"></i> Lưu thay đổi
                                </button>
                            </div>
                            <div class="col-md-6">
                                <a asp-action="ChangePassword" class="btn-action btn-pass">
                                    <i class="fa-solid fa-key"></i> Đổi mật khẩu
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Scroll Reveal
        document.addEventListener('DOMContentLoaded', () => {
            const items = document.querySelectorAll('.reveal');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.1 });

            items.forEach(item => observer.observe(item));
        });
    </script>
}