@model ProductListViewModel

@{
    ViewData["Title"] = "Sản phẩm - PhoneShop Tech";
}

<style>
    /* 1. IMPORT FONT & VARIABLES */
    @@import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800;900&display=swap');

    :root {
        --light-bg: #ffffff;
        --light-surface: #f8f9fa;
        --light-border: #e2e8f0;
        --tech-blue: #0066ff;
        --tech-cyan: #00bcd4;
        --text-primary: #1e293b;
        --text-secondary: #64748b;
        --font-main: 'Be Vietnam Pro', sans-serif;
        --shadow-card: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        --shadow-hover: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
    }

    /* 2. GENERAL LAYOUT */
    .product-page-wrapper {
        font-family: var(--font-main) !important;
        background-color: var(--light-bg);
        color: var(--text-primary);
        min-height: 100vh;
        font-size: 1.6rem;
        padding-bottom: 80px;
        /* Họa tiết lưới Dot Grid */
        background-image: radial-gradient(var(--light-border) 1px, transparent 1px);
        background-size: 30px 30px;
    }

    /* 3. HEADER */
    .page-header {
        padding: 60px 0 40px;
        text-align: center;
        background: linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(248,249,250,0.8) 100%);
        border-bottom: 1px dashed var(--light-border);
        margin-bottom: 40px;
    }

    .page-title {
        font-family: Be Vietnam Pro;
        font-size: 4.5rem;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--text-primary);
        letter-spacing: -1px;
        margin-bottom: 10px;
    }

    .breadcrumb-nav {
        display: inline-block;
        font-size: 1.6rem;
        color: var(--text-secondary);
        background: #fff;
        padding: 5px 15px;
        border: 1px solid var(--light-border);
        border-radius: 99px;
    }

        .breadcrumb-nav a {
            text-decoration: none;
            color: var(--text-secondary);
            font-weight: 500;
            transition: 0.2s;
        }

            .breadcrumb-nav a:hover {
                color: var(--tech-blue);
            }

        .breadcrumb-nav .active {
            color: var(--tech-blue);
            font-weight: 700;
        }

    /* 4. SIDEBAR (FILTER) */
    .filter-card {
        background: #fff;
        border-radius: 12px;
        padding: 24px;
        border: 1px solid var(--light-border);
        position: sticky;
        top: 100px;
        box-shadow: var(--shadow-card);
    }

    .filter-title {
        font-family: Be Vietnam Pro;
        font-size: 1.8rem;
        font-weight: 800;
        margin-bottom: 20px;
        text-transform: uppercase;
        color: var(--text-primary);
        border-bottom: 2px solid var(--light-surface);
        padding-bottom: 10px;
    }

    .category-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .cat-link {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 16px;
        border-radius: 8px;
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 1.6rem;
        font-weight: 500;
        transition: 0.2s;
        margin-bottom: 8px;
        border: 1px solid transparent;
    }

        .cat-link:hover {
            background: var(--light-surface);
            color: var(--tech-blue);
            border-color: var(--light-border);
            transform: translateX(5px);
        }

        .cat-link.active {
            background: var(--tech-blue);
            color: #fff;
            box-shadow: 0 4px 12px rgba(0, 102, 255, 0.2);
        }

            .cat-link.active .count {
                background: rgba(255,255,255,0.2);
                color: #fff;
            }

        .cat-link .count {
            font-size: 1.4rem;
            background: var(--light-surface);
            padding: 2px 10px;
            border-radius: 99px;
            color: var(--text-secondary);
            font-weight: 600;
        }

    /* 5. TOOLBAR & SEARCH */
    .search-input {
        width: 100%;
        padding: 12px 20px;
        padding-right: 50px;
        border-radius: 8px;
        border: 1px solid var(--light-border);
        font-size: 1.6rem;
        font-family: var(--font-main);
        outline: none;
        transition: 0.3s;
        background: #fff;
    }

        .search-input:focus {
            border-color: var(--tech-blue);
            box-shadow: 0 0 0 3px rgba(0, 102, 255, 0.1);
        }

    .search-btn {
        position: absolute;
        right: 5px;
        top: 50%;
        transform: translateY(-50%);
        background: var(--tech-blue);
        color: #fff;
        border: none;
        width: 36px;
        height: 36px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.2s;
    }

        .search-btn:hover {
            background: #0052cc;
        }

    /* 6. PRODUCT CARD (TECH STYLE) */
    .pro-card {
        background: #fff;
        border-radius: 12px;
        border: 1px solid var(--light-border);
        transition: all 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        position: relative;
        overflow: hidden;
    }

        .pro-card:hover {
            transform: translateY(-5px);
            border-color: var(--tech-blue);
            box-shadow: var(--shadow-hover);
        }

    /* Badge */
    .pro-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        z-index: 2;
        padding: 4px 12px;
        border-radius: 4px;
        font-size: 1.2rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .badge-new {
        background: var(--tech-blue);
        color: #fff;
    }

    .badge-low {
        background: #f59e0b;
        color: #fff;
    }

    .badge-out {
        background: #ef4444;
        color: #fff;
    }

    /* Image */
    .pro-img-wrap {
        height: 240px;
        padding: 20px;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        border-bottom: 1px dashed var(--light-border);
        position: relative;
    }

        /* Hiệu ứng nền grid mờ dưới ảnh */
        .pro-img-wrap::before {
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            background-image: radial-gradient(#e2e8f0 1px, transparent 1px);
            background-size: 15px 15px;
            opacity: 0.5;
            z-index: 0;
        }

        .pro-img-wrap img {
            max-height: 100%;
            max-width: 100%;
            object-fit: contain;
            transition: transform 0.5s;
            z-index: 1;
        }

    .pro-card:hover .pro-img-wrap img {
        transform: scale(1.08);
    }

    /* Details */
    .pro-details {
        padding: 20px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .pro-cat {
        font-size: 1.2rem;
        color: var(--tech-cyan);
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 5px;
    }

    .pro-title a {
        color: var(--text-primary);
        text-decoration: none;
        font-size: 1.8rem;
        font-weight: 700;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.4;
        transition: 0.2s;
    }

        .pro-title a:hover {
            color: var(--tech-blue);
        }

    /* Price */
    .pro-price {
        font-size: 2rem;
        font-weight: 800;
        color: var(--tech-blue);
        margin: 10px 0;
    }

    /* Action Buttons Group */
    .pro-actions {
        display: grid;
        grid-template-columns: 1fr 1fr; /* Chia đôi 50-50 */
        gap: 10px;
        margin-top: auto;
    }

    .btn-card {
        padding: 10px;
        font-size: 1.4rem;
        font-weight: 600;
        border-radius: 6px;
        text-align: center;
        cursor: pointer;
        transition: 0.3s;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        text-decoration: none;
    }

    /* Nút xem chi tiết (Outline) */
    .btn-detail {
        background: transparent;
        border: 1px solid var(--light-border);
        color: var(--text-secondary);
    }

        .btn-detail:hover {
            border-color: var(--text-primary);
            color: var(--text-primary);
            background: #fff;
        }

    /* Nút thêm vào giỏ (Solid) */
    .btn-add {
        background: var(--tech-blue);
        color: #fff;
        border: 1px solid var(--tech-blue);
    }

        .btn-add:hover:not(:disabled) {
            background: #0052cc;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 102, 255, 0.25);
        }

        .btn-add:disabled {
            background: #e2e8f0;
            border-color: #e2e8f0;
            color: #94a3b8;
            cursor: not-allowed;
        }

    /* 7. PAGINATION */
    .pagination-modern .page-link {
        border: 1px solid var(--light-border);
        margin: 0 4px;
        width: 40px;
        height: 40px;
        border-radius: 8px; /* Vuông bo góc */
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-primary);
        font-weight: 600;
        background: #fff;
        font-size: 1.6rem;
    }

        .pagination-modern .page-link:hover {
            border-color: var(--tech-blue);
            color: var(--tech-blue);
        }

    .pagination-modern .active .page-link {
        background: var(--tech-blue);
        color: #fff;
        border-color: var(--tech-blue);
    }

    /* Animation */
    .reveal {
        opacity: 0;
        transform: translateY(20px);
        transition: 0.5s ease-out;
    }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }
</style>

<div class="product-page-wrapper">
    <section class="page-header">
        <div class="container">
            <h1 class="page-title">Cửa hàng</h1>
            <div class="breadcrumb-nav">
                <a asp-controller="Home" asp-action="Index">Trang chủ</a>
                <span class="mx-2">/</span>
                <span class="active">Sản phẩm</span>
            </div>
        </div>
    </section>

    <section class="container pb-5">
        <div class="row">
            <div class="col-lg-3 col-md-4 mb-4 reveal">
                <div class="filter-card">
                    <h4 class="filter-title"><i class="fa-solid fa-filter me-2"></i> Bộ lọc</h4>
                    <ul class="category-list">
                        <li>
                            <a asp-controller="Product" asp-action="Index"
                               class="cat-link @(Model.SelectedCategoryId == null ? "active" : "")">
                                <span>Tất cả sản phẩm</span>
                                <span class="count">@Model.TotalProducts</span>
                            </a>
                        </li>
                        @foreach (var category in Model.Categories)
                        {
                            <li>
                                <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@category.CategoryId"
                                   class="cat-link @(Model.SelectedCategoryId == category.CategoryId ? "active" : "")">
                                    <span>@category.CategoryName</span>
                                    <span class="count"><i class="fa-solid fa-angle-right"></i></span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <div class="col-lg-9 col-md-8">
                <div class="toolbar-area reveal" style="transition-delay: 0.1s; margin-bottom: 30px;">
                    <div class="row align-items-center">
                        <div class="col-md-7 mb-3 mb-md-0">
                            <form asp-controller="Product" asp-action="Index" method="get" class="position-relative">
                                <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                                <input type="text" name="search" value="@Model.SearchTerm"
                                       class="search-input" placeholder="Tìm kiếm tên thiết bị...">
                                <button type="submit" class="search-btn"><i class="fa-solid fa-magnifying-glass"></i></button>
                            </form>
                        </div>
                        <div class="col-md-5 text-md-end text-secondary" style="font-size: 1.5rem;">
                            Hiển thị <strong>@Model.Products.Count</strong> thiết bị
                        </div>
                    </div>
                </div>

                @if (!Model.Products.Any())
                {
                    <div class="text-center py-5 reveal">
                        <i class="fa-solid fa-box-open mb-3" style="font-size: 5rem; color: #e2e8f0;"></i>
                        <h3 style="font-weight: 700; color: var(--text-primary)">Không tìm thấy dữ liệu</h3>
                        <p class="text-secondary">Thử tìm kiếm với từ khóa khác hoặc xóa bộ lọc.</p>
                        <a asp-action="Index" class="btn btn-outline-primary mt-2" style="border-radius: 8px;">Xóa bộ lọc</a>
                    </div>
                }
                else
                {
                    <div class="row g-4">
                        @foreach (var product in Model.Products)
                        {
                            <div class="col-6 col-lg-4 reveal" style="transition-delay: 0.2s">
                                <article class="pro-card">
                                    @if (product.Stock <= 0)
                                    {
                                        <span class="pro-badge badge-out">Hết hàng</span>
                                    }
                                    else if (product.Stock < 10)
                                    {
                                        <span class="pro-badge badge-low">Sắp hết</span>
                                    }
                                    else
                                    {
                                        <span class="pro-badge badge-new">Mới</span>
                                    }

                                    <div class="pro-img-wrap">
                                        <a asp-controller="Product" asp-action="Detail" asp-route-id="@product.ProductId">
                                            <img src="@ShopMVC.Helpers.ImageHelper.GetProductImagePath(product.Image)"
                                                 alt="@product.ProductName" />
                                        </a>
                                    </div>

                                    <div class="pro-details">
                                        <div class="pro-cat">@product.Category?.CategoryName</div>
                                        <h3 class="pro-title">
                                            <a asp-controller="Product" asp-action="Detail" asp-route-id="@product.ProductId" title="@product.ProductName">
                                                @product.ProductName
                                            </a>
                                        </h3>

                                        <div class="pro-price">@product.Price.ToString("N0")₫</div>

                                        <div class="pro-actions">
                                            <a asp-controller="Product" asp-action="Detail" asp-route-id="@product.ProductId"
                                               class="btn-card btn-detail">
                                                <i class="fa-regular fa-eye"></i> Chi tiết
                                            </a>

                                            <button type="button"
                                                    class="btn-card btn-add add-to-cart-btn"
                                                    data-product-id="@product.ProductId"
                                                    @(product.Stock <= 0 ? "disabled" : "")>
                                                <i class="fa-solid fa-cart-plus"></i> Thêm
                                            </button>
                                        </div>
                                    </div>
                                </article>
                            </div>
                        }
                    </div>

                    @if (Model.TotalPageCount > 1)
                    {
                        <div class="mt-5 reveal">
                            <nav aria-label="Page navigation">
                                <ul class="pagination pagination-modern justify-content-center">
                                    @if (Model.HasPreviousPage)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" asp-action="Index"
                                               asp-route-page="@(Model.Page - 1)"
                                               asp-route-categoryId="@Model.SelectedCategoryId"
                                               asp-route-search="@Model.SearchTerm">
                                                <i class="fa-solid fa-chevron-left"></i>
                                            </a>
                                        </li>
                                    }

                                    @for (int i = 1; i <= Model.TotalPageCount; i++)
                                    {
                                        <li class="page-item @(i == Model.Page ? "active" : "")">
                                            <a class="page-link" asp-action="Index"
                                               asp-route-page="@i"
                                               asp-route-categoryId="@Model.SelectedCategoryId"
                                               asp-route-search="@Model.SearchTerm">
                                                @i
                                            </a>
                                        </li>
                                    }

                                    @if (Model.HasNextPage)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" asp-action="Index"
                                               asp-route-page="@(Model.Page + 1)"
                                               asp-route-categoryId="@Model.SelectedCategoryId"
                                               asp-route-search="@Model.SearchTerm">
                                                <i class="fa-solid fa-chevron-right"></i>
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        </div>
                    }
                }
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        // Scroll Reveal Animation
        document.addEventListener('DOMContentLoaded', () => {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.1 });

            document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
        });
    </script>
    <script src="~/js/cart.js"></script>
}